# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# llama-3.3-70b-versatile is the strongest free-tier text model on Groq as of
# mid-2026. If it's deprecated by the time you read this, run:
#   curl https://api.groq.com/openai/v1/models -H "Authorization: Bearer $GROQ_API_KEY"
# and swap in whatever's current.
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.0
GROQ_MAX_RETRIES=2

# Layer 2: Context Graph - point at your already-running Neo4j instance
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ENV=dev
